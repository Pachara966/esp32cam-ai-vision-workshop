# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit API keys.

# -------------------------------------------------------------------
# Vision AI provider: mock | gemini | claude
# Use "mock" for Lab 02 (no API key needed).
# Switch to "gemini" or "claude" for Lab 03.
# -------------------------------------------------------------------
VISION_PROVIDER=mock

# -------------------------------------------------------------------
# Google Gemini Vision API key
# Get it from: https://aistudio.google.com/app/apikey
# -------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# -------------------------------------------------------------------
# Anthropic Claude Vision API key
# Get it from: https://console.anthropic.com/
# -------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5

# -------------------------------------------------------------------
# Default ESP32-CAM URL (optional — can also be set in the web UI)
# Example: http://192.168.1.50
# -------------------------------------------------------------------
CAM_URL=
